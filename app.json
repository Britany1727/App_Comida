{
  "expo": {
    "name": "Prueba1",
    "slug": "Prueba1",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "prueba1",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.britany1727.Prueba1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE"
      }, 
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "package": "com.britany1727.Prueba1"
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysPermission": "Permitir que la app acceda a tu ubicación."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/comida.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "441479f4-1593-42ea-ad71-7ed2db7d321d"
      }
    }
  }
}
